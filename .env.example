# Server
PORT=3001
NODE_ENV=development

# Database (Neon hosted PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-long-random-string-min-64-chars
JWT_REFRESH_SECRET=replace-with-another-long-random-string-min-64-chars

# Resend (email delivery — resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=FAZN <noreply@fazn.dev>

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CALLBACK_URL=https://api.fazn.dev/api/v1/auth/oauth/google/callback

# Apple OAuth (developer.apple.com — Sign In with Apple)
APPLE_CLIENT_ID=com.fazn.musabello.app
APPLE_TEAM_ID=TY2W2ZDP3W
APPLE_KEY_ID=XXXXXXXXXX
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXX\n-----END PRIVATE KEY-----"
APPLE_CALLBACK_URL=https://api.fazn.dev/api/v1/auth/oauth/apple/callback

# Mobile deep-link redirect after OAuth
FRONTEND_REDIRECT_URL=fazn://auth

# Paystack (paystack.com → Settings → API Keys)
# Use the live secret key for production, test secret key for staging/dev
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here
# URL Paystack redirects to after card payment (must be whitelisted in Paystack dashboard)
PAYSTACK_CALLBACK_URL=https://api.fazn.dev/api/v1/wallet/redirect
