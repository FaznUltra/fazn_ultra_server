# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fazn

# JWT
JWT_ACCESS_SECRET=replace-with-long-random-string-min-64-chars
JWT_REFRESH_SECRET=replace-with-another-long-random-string-min-64-chars

# Resend (email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=FAZN <noreply@yourdomain.com>

# Google OAuth
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# Apple OAuth
APPLE_CLIENT_ID=com.yourcompany.fazn
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXX\n-----END PRIVATE KEY-----"
APPLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/apple/callback

# Frontend deep-link redirect after OAuth
FRONTEND_REDIRECT_URL=yourapp://auth
